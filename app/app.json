{
  "expo": {
    "name": "EgoUploader",
    "slug": "EgoUploader",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "egouploader",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "EgoUploader needs camera access to record egocentric video clips.",
        "NSMicrophoneUsageDescription": "EgoUploader needs microphone access to record audio with video clips."
      },
      "bundleIdentifier": "com.anonymous.EgoUploader"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.EgoUploader"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "EgoUploader needs camera access to record egocentric video clips.",
          "enableMicrophonePermission": true,
          "microphonePermissionText": "EgoUploader needs microphone access to record audio with video clips."
        }
      ],
      "./plugins/withHandDetection"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
